{
  "system": "M-flow",
  "version": "0.3.2+ (GitHub main, commit 3afcb94)",
  "deployment": "Docker (built from source)",

  "llm_ingest": {
    "model": "openai/gpt-5-nano",
    "provider": "openai",
    "note": "Used for Episode summarization during ingestion"
  },
  "llm_answer": {
    "model": "gpt-5-mini",
    "temperature": "default (1) — gpt-5-mini does not support temperature=0",
    "max_tokens": "not set (model default)",
    "note": "Non-deterministic; results vary ±1-2% between runs"
  },
  "llm_judge": {
    "model": "gpt-4o-mini",
    "temperature": 0.0,
    "response_format": "json_object",
    "max_tokens": "not set",
    "note": "Deterministic"
  },
  "embedding": {
    "model": "openai/text-embedding-3-small",
    "dimensions": 1536,
    "provider": "openai"
  },
  "retrieval": {
    "top_k": 10,
    "method": "EpisodicRetriever (vector search + graph projection + bundle scoring)"
  },
  "ingestion": {
    "precise_mode": true,
    "episodic_routing": true,
    "batching": "3-3-4 (3 parallel workers per batch)",
    "total_ingestion_time": "10h 39m"
  },
  "database": {
    "relational": "SQLite",
    "vector": "LanceDB",
    "graph": "KuzuDB"
  },
  "dataset": {
    "name": "LoCoMo-10",
    "source": "https://github.com/snap-research/LoCoMo",
    "file": "locomo10.json",
    "conversations": 10,
    "total_questions": 1986,
    "evaluated_questions": 1541,
    "excluded": "Category 5 (Adversarial, 446 questions, no gold answers)"
  }
}
